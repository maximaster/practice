<?xml version="1.0"?>
<ruleset name="Recall"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>
        Tuned PHPMD ruleset for the Recall backend. Strict where it pays off;
        idiom-fighting rules that overlap PHPStan or quarrel with the router /
        value-object / factory style are switched off deliberately.
    </description>

    <rule ref="rulesets/cleancode.xml">
        <!-- Static factories (Response::json) and value-object constructors are by design. -->
        <exclude name="StaticAccess"/>
        <!-- Validation helpers legitimately take boolean-ish flags. -->
        <exclude name="BooleanArgumentFlag"/>
        <!-- Early returns already keep nesting flat; a final else is sometimes clearer. -->
        <exclude name="ElseExpression"/>
    </rule>

    <rule ref="rulesets/codesize.xml">
        <!-- Сводный typecast — плоский match по типам VO; цикломатика тут ложная. -->
        <exclude name="CyclomaticComplexity"/>
    </rule>
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="15"/>
        </properties>
    </rule>

    <rule ref="rulesets/controversial.xml">
        <!-- Request::fromGlobals reads $_SERVER / $_GET on purpose. -->
        <exclude name="Superglobals"/>
    </rule>

    <rule ref="rulesets/design.xml">
        <!-- Сериализатор/ORM/бутстрап — точки сборки, высокая связанность здесь нормальна. -->
        <exclude name="CouplingBetweenObjects"/>
    </rule>

    <rule ref="rulesets/naming.xml">
        <!-- $id, $r, $c, $m are fine; PHPStan already enforces real typing. -->
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
    </rule>

    <rule ref="rulesets/unusedcode.xml">
        <!-- Controller actions share a uniform (Request, int) signature; not every action uses it. -->
        <exclude name="UnusedFormalParameter"/>
    </rule>
</ruleset>
